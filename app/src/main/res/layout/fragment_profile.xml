<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:elevation="0dp"
        android:background="@color/primary_maroon">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="4dp"
                app:strokeWidth="3dp"
                app:strokeColor="@android:color/white">

                <ImageView
                    android:id="@+id/imgProfileAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:scaleType="centerCrop"
                    android:background="@color/primary_maroon_light"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <!-- Profile Name & Role Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nama Pengguna"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textAlignment="center" />

                    <TextView
                        android:id="@+id/tvProfileRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jabatan: Perangkat Desa"
                        android:textColor="@color/primary_maroon"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"
                        android:textAlignment="center" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Details Section Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Informasi Kontak &amp; Kantor"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="8dp" />

            <!-- Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Phone Number -->
                    <TextView
                        android:id="@+id/tvProfilePhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0812-3456-7890"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:padding="14dp"
                        android:drawableStart="@android:drawable/ic_menu_call"
                        android:drawablePadding="16dp"
                        android:drawableTint="@color/primary_maroon"
                        android:gravity="center_vertical" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginHorizontal="16dp" />

                    <!-- Email Address -->
                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="pengguna@binadesa.go.id"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:padding="14dp"
                        android:drawableStart="@android:drawable/ic_dialog_email"
                        android:drawablePadding="16dp"
                        android:drawableTint="@color/primary_maroon"
                        android:gravity="center_vertical" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginHorizontal="16dp" />

                    <!-- Office Address -->
                    <TextView
                        android:id="@+id/tvProfileOffice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Jl. Raya Bina Desa No. 10, Kantor Desa Bina Desa"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:padding="14dp"
                        android:drawableStart="@android:drawable/ic_dialog_map"
                        android:drawablePadding="16dp"
                        android:drawableTint="@color/primary_maroon"
                        android:gravity="center_vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Ubah Profil Pengguna"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/primary_maroon"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconGravity="textStart"
                app:elevation="2dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProfileLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Keluar dari Akun"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/accent_red"
                app:backgroundTint="@color/bg_light"
                app:strokeColor="@color/accent_red"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconGravity="textStart"
                app:iconTint="@color/accent_red"
                app:elevation="0dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>