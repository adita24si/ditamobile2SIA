<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:background="@color/primary_maroon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="38dp"
        android:scaleType="fitCenter"
        android:src="@drawable/logoadita"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Main Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/primary_maroon_light"
        app:strokeWidth="2dp"
        app:cardBackgroundColor="@color/surface_card"
        app:layout_constraintTop_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp">

            <!-- Judul -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sistem Informasi Produk Hukum"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/primary_maroon_dark"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dokumen Publik Bina Desa"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="28dp"/>

            <!-- Menu -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Utama"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="@color/primary_maroon_dark"
                android:layout_marginBottom="24dp"/>

            <!-- Tombol Portal -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWebsite"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Akses Portal Dokumen Publik"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/primary_maroon"
                app:cornerRadius="20dp"
                android:layout_marginBottom="16dp"/>

            <!-- Tombol Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Logout Sistem"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/primary_maroon_dark"
                app:cornerRadius="20dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Layanan Digital Regulasi dan Dokumen Publik Desa"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>