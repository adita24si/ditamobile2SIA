<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_maroon">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarDetail"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Detail Produk Hukum"
            app:titleCentered="true"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Category & Status Badge Layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/primary_maroon_light"
                    app:strokeWidth="0dp">
                    <TextView
                        android:id="@+id/tvDetailCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peraturan Desa"
                        android:textColor="@color/primary_maroon"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E6F4EA"
                    app:strokeWidth="0dp">
                    <TextView
                        android:id="@+id/tvDetailStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Berlaku"
                        android:textColor="@color/accent_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Title & Doc Number -->
            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Peraturan Desa Nomor 3 Tahun 2025"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvDetailDocNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nomor Dokumen: 03/PERDES/2025"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="24dp" />

            <!-- Document Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deskripsi Lengkap Dokumen"
                        android:textColor="@color/primary_maroon"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvDetailDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam id lorem vel velit rhoncus tristique. Nullam molestie ex id justo posuere aliquet. Vivamus at neque hendrerit, scelerisque nisl quis, elementum ex."
                        android:textColor="@color/secondary_grey"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- More Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Informasi Tambahan"
                        android:textColor="@color/primary_maroon"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Item Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Tahun Terbit"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/tvDetailYear"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="2025"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Item Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Kategori"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/tvDetailCategoryRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Peraturan Desa"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Item Row 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Tingkat Akses"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Publik / Perangkat Desa"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Download Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownloadPdf"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Unduh PDF Dokumen (Dummy)"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/primary_maroon"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/stat_sys_download"
                app:iconGravity="textStart"
                app:elevation="4dp"
                android:layout_marginBottom="12dp" />

            <!-- Reminder Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetReminder"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Ingatkan Saya Membaca ⏰"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/biru_cantik"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_alarm"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:elevation="4dp"
                android:layout_marginBottom="24dp" />


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
